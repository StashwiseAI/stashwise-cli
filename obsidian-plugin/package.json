{
  "name": "stashwise-obsidian",
  "version": "0.1.0",
  "description": "Obsidian plugin that syncs a Stashwise wiki into a local vault.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "check": "tsc --noEmit",
    "dev": "node esbuild.config.mjs",
    "install:local": "npm run build && node scripts/install-local.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.4.0"
  }
}
